{
  "name": "panel-de-cirugias",
  "private": true,
  "version": "3.10.49",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/supabase-js": "^2.39.7",
    "buffer": "^6.0.3",
    "builder-util-runtime": "^9.5.1",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^2.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "fs-extra": "^11.2.0",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.344.0",
    "obs-websocket-js": "^5.0.6",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.7",
    "react-router-dom": "^6.22.2",
    "react-signature-canvas": "1.1.0-alpha.2",
    "recharts": "^2.12.2",
    "tailwind-merge": "^2.2.1",
    "universalify": "^2.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.iteo.panelcirugias",
    "productName": "Panel de Cirugias ITEO",
    "artifactName": "PanelCirugias_ITEO_Setup.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "lynxok",
        "repo": "iteopanelcirugias",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json",
      "node_modules/**/*",
      "CONFIGURAR_SINCRONIZADOR.bat"
    ],
    "extraResources": [
      {
        "from": "sai-scraper/sai-scraper",
        "to": ".",
        "filter": [
          "**/*",
          "!venv/**/*",
          "!.git/**/*"
        ]
      }
    ],
    "win": {
      "icon": "dist/favicon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "runAfterFinish": true,
      "unicode": true
    }
  }
}
